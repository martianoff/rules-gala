common --enable_bzlmod
common --noenable_workspace

build --java_runtime_version=remotejdk_17 --enable_runfiles

# Allow downstream rules' Go type inference to find the SDK on host.
build --action_env=GOROOT
build --action_env=PATH

# Recycle persistent workers between builds to avoid Windows file locks
# on gala_worker.exe.
build --worker_quit_after_build

# Pick up local user overrides if present.
try-import %workspace%/user.bazelrc
